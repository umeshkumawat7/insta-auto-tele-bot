# ─── Telegram ────────────────────────────────────────────────────────────────
BOT_TOKEN=
TELEGRAM_API=https://api.telegram.org/bot

# ─── Instagram Graph API ─────────────────────────────────────────────────────
IG_ACCESS_TOKEN=
IG_USER_ID=

# ─── Neon PostgreSQL ─────────────────────────────────────────────────────────
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=

# ─── Cloudinary Storage ──────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Security ────────────────────────────────────────────────────────────────
# Your Telegram chat_id — bot will ONLY respond to this ID
# Get it by messaging @userinfobot on Telegram
ALLOWED_CHAT_ID=
